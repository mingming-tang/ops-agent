# ====== 应用 ======
APP_HOST=0.0.0.0
APP_PORT=8000

# ====== 数据库 ======
# 开发默认 SQLite(开箱即用);生产用 Postgres:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/operator_agent
DATABASE_URL=sqlite:///./operator_agent.db

# LangGraph checkpointer(持久化/续跑)。留空则用内存 checkpointer(重启丢失)。
# 生产建议指向 Postgres:postgresql://user:pass@localhost:5432/operator_agent
CHECKPOINT_DB_URL=

# ====== 安全 ======
# 凭证加密主密钥(Fernet)。生成:python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=CHANGE_ME_GENERATE_A_FERNET_KEY

# 后台 admin 登录(简单起步,生产请换成正式鉴权)
ADMIN_TOKEN=change-me

# ====== 默认安全策略 ======
# 危险命令是否强制人工审批
REQUIRE_APPROVAL_FOR_DANGEROUS=true
# 是否默认 dry-run(只展示不执行变更)
DEFAULT_DRY_RUN=false
